# MongoDB Configuration
# Replace with your actual MongoDB connection string
# DO NOT include password in version control
MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/billing-system

# JWT Configuration
# Generate a strong random secret (at least 32 characters)
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-chars-change-this-in-production

# Admin Configuration
# The email address that will receive Admin role on first signup
ADMIN_EMAIL=admin@yourdomain.com

# Server Configuration
PORT=3000
NODE_ENV=development

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Azure / Microsoft Graph API Configuration
AZURE_CLIENT_ID=your-client-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-client-secret
SHAREPOINT_SITE_ID=your-sharepoint-site-id

# Logging
LOG_LEVEL=info
